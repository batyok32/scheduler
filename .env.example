# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# Required for browser / admin POSTs via ngrok or other HTTPS tunnels (scheme + host, no path).
# The hostname is also appended to ALLOWED_HOSTS automatically.
# DJANGO_CSRF_TRUSTED_ORIGINS=https://YOUR-SUBDOMAIN.ngrok-free.app

# Cal.com: full HTTP request/response logging (defaults to DJANGO_DEBUG if unset; legacy RETELL_LOG_FULL_RESPONSES also applies when CALCOM_VERBOSE_LOGS is unset).
# CALCOM_VERBOSE_LOGS=True
# Retell: full webhook JSON + stderr debug lines (default off).
# RETELL_LOG_VERBOSE=True

# Retell (webhook badge API key — used for x-retell-signature verification)
RETELL_API_KEY=

# Cal.com API v2 (Bearer token is usually your API key prefixed with cal_)
CALCOM_API_KEY=
# Bookings (list/create/reschedule/cancel) — Cal.com currently documents 2026-02-25
CALCOM_BOOKINGS_API_VERSION=2026-02-25
# Slots — Cal.com documents 2024-09-04 for GET /slots
CALCOM_SLOTS_API_VERSION=2024-09-04
# Event types — GET /event-types (see Cal.com docs; default 2024-06-14)
CALCOM_EVENT_TYPES_API_VERSION=2024-06-14
# Legacy alias (defaults to bookings version if set alone)
CALCOM_API_VERSION=2026-02-25
CALCOM_BASE_URL=https://api.cal.com/v2
CALCOM_REQUEST_TIMEOUT=30
CALCOM_MAX_RETRIES=2

DEFAULT_TIMEZONE=America/Los_Angeles

# Multi-service catalog (JSON object): maps service_key -> { event_type_id, label, description [, duration_minutes_options] }
# Optional duration_minutes_options: e.g. [30,60,90] — first value used when the request omits duration or sends one not in the list; a single-element list is always used for resolution and omits lengthInMinutes on Cal.com create/reschedule (fixed-length event types).
# Optional omit_length_in_minutes: true — force omit lengthInMinutes when Cal.com fixed-length but you do not use duration_minutes_options.
# If unset, built-in defaults in settings apply. Agents should use service_key only in prompts.
# SERVICE_CATALOG_JSON={"repair_request":{"event_type_id":100,"label":"Repair request","description":"...","duration_minutes_options":[60,90]},"repair_estimate":{"event_type_id":101,"label":"Repair estimate","description":"...","duration_minutes_options":[45]}}

# Optional PostgreSQL, e.g. postgres://user:pass@localhost:5432/scheduler
# Leave unset to use SQLite at db.sqlite3
DATABASE_URL=

LOG_LEVEL=INFO
